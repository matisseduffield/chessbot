# Backend environment variables
#
# Copy this file to backend/.env (gitignored) and uncomment any lines
# you want to override. All vars are optional — defaults resolve
# relative to the repository root.
#
# Validated at startup by backend/config.js via zod. An invalid value
# aborts boot with a readable error rather than degrading silently.

# Port the HTTP + WS server listens on (1-65535).
# PORT=8080

# Directory containing engine binaries (stockfish/, fairy-stockfish/).
# ENGINE_DIR=../engine

# Directory containing polyglot .bin opening books.
# BOOKS_DIR=../books

# Directory containing Syzygy endgame tablebases.
# SYZYGY_DIR=../syzygy

# Explicit engine binary paths. Override if the defaults don't match
# your platform (the default assumes Windows x86-64 AVX2).
# STOCKFISH_PATH=../engine/stockfish/stockfish-windows-x86-64-avx2.exe
# FAIRY_STOCKFISH_PATH=../engine/fairy-stockfish/fairy-stockfish_x86-64-bmi2.exe

# Explicit opening-book path. If unset, the first .bin in BOOKS_DIR
# is auto-selected at startup.
# OPENING_BOOK_PATH=../books/Balsa3500.bin

# Syzygy tablebase path passed to the engine's SyzygyPath UCI option.
# Multiple folders can be joined with ';' on Windows or ':' on *nix.
# Set to "" to disable tablebases entirely.
# SYZYGY_PATH=../syzygy
