{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "src/engine/uciParser.js",
    "src/engine/searchLimits.js",
    "src/engine/evalCache.js",
    "src/ws/send.js",
    "src/ws/rateLimit.js"
  ]
}
