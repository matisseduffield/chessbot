{
  "name": "chessbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chess analysis tool: extension + local Stockfish backend.",
  "workspaces": [
    "shared",
    "backend",
    "backend/panel",
    "extension"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm run build --workspace @chessbot/shared",
    "start": "npm run build:shared && node backend/server.js",
    "dev": "npm run build:shared && node backend/server.js",
    "doctor": "node scripts/doctor.mjs",
    "setup:engine": "node scripts/setup-engine.mjs",
    "postinstall": "npm run build:shared --if-present",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "e2e": "playwright test --config config/playwright.config.js",
    "e2e:ui": "playwright test --config config/playwright.config.js --ui",
    "typecheck": "tsc -b && npm run typecheck --workspace backend",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.0",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "engines": {
    "node": ">=20"
  }
}
