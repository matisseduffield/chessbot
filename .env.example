# Chessbot backend environment variables.
# Copy this file to `.env` (in the repo root) and edit values as needed.
# Everything is optional — sensible defaults are baked into backend/config.js.

# ── Server ──────────────────────────────────────────────
# Port the dashboard + WebSocket bind to.
# PORT=8080

# Address the server binds to.
#   127.0.0.1 (default) — only this machine can connect (recommended for OBS / streaming setups).
#   0.0.0.0           — expose on the LAN so a phone or second PC can view the dashboard.
# See docs/streaming.md for the streaming workflow.
# BIND_HOST=127.0.0.1

# ── Logging ─────────────────────────────────────────────
# fatal | error | warn | info | debug | trace | silent
# LOG_LEVEL=info

# ── Engine paths ────────────────────────────────────────
# By default the backend probes ./engine/stockfish/ and ./engine/fairy-stockfish/
# for the right binary for your OS. Set these to override the autodetect.
# STOCKFISH_PATH=
# FAIRY_STOCKFISH_PATH=

# ── Resource paths ──────────────────────────────────────
# Folders the dashboard scans for available files.
# ENGINE_DIR=
# BOOKS_DIR=
# SYZYGY_DIR=

# Specific opening book + Syzygy tablebase folder used by the engine.
# OPENING_BOOK_PATH=
# SYZYGY_PATH=
