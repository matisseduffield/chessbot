{
  "name": "@chessbot/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, schemas, and utilities used by the backend and extension.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./messages": {
      "types": "./dist/messages.d.ts",
      "default": "./dist/messages.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.1"
  }
}
